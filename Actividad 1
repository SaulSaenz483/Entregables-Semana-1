Perro.cpp

#include "Perro.h"

Perro::Perro(string nombre, string alimentacion, string tam) : Mamifero(nombre, alimentacion)
{
    this->tam = tam;
}

Perro::~Perro()
{
    // cout << "Perro destruido\n";
}

void Perro::mostrarAnimal()
{
    Mamifero::mostrarAnimal();
    cout << "Perro Tamano: " << tam << endl;
}

Main.cpp

#include "Animal.h"
#include "Mamifero.h"
#include "Perro.h"
using namespace std;

int main() {

    Perro perro("Nala", "Omnivoro", "Pequeno");

    Animal* a1 = &perro;

    Mamifero* m1 = &perro;

    a1->mostrarAnimal();
    cout << "===================\n";
    m1->mostrarAnimal();

    return 0;
}
