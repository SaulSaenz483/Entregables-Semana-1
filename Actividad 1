*Justifique en el archivo MD qué tipo de relación existe entre las clases y por qué el upcast es seguro.
Existe una relación de herencia, donde Mamifero es una especialización de Animal. 
Esto significa que un mamífero es un animal, ya que comparte sus características básicas y además puede agregar otras propias.
El upcast es seguro porque un objeto Mamifero también es un Animal, entonces puede tratarse como tal sin problema. 
No se pierde información, simplemente se está viendo el objeto desde una forma más general.

Animal.h

#ifndef ACTIVIDAD1_ANIMAL_H
#define ACTIVIDAD1_ANIMAL_H
#include <iostream>
using namespace std;

class Animal{
protected:
    string nombre;
public:
    Animal(string nombre);
    virtual ~Animal();
    virtual void mostrarAnimal() = 0;
};


#endif //ACTIVIDAD1_ANIMAL_H

Animal.cpp

#include "Animal.h"

Animal::Animal(string nombre){
    this->nombre = nombre;
}
Animal::~Animal()
{
    // cout << "Se ha destruido un animal\n";
}

void Animal::mostrarAnimal()
{
    cout << "Animal nombre: " << nombre << endl;
}

Mamifero.h

#ifndef ACTIVIDAD1_MAMIFERO_H
#define ACTIVIDAD1_MAMIFERO_H
#include "Animal.h"

class Mamifero : public Animal
{
protected:
    string alimentacion;
public:
    Mamifero(string alimentacion, string nombre);
    virtual ~Mamifero();
    void mostrarAnimal()override;


};


#endif //ACTIVIDAD1_MAMIFERO_H

Mamifero.cpp

#include "Mamifero.h"

Mamifero::Mamifero(string nombre, string alimentacion) : Animal(nombre)
{
    this->alimentacion = alimentacion;
}
Mamifero::~Mamifero()
{
    // cout << "Mamifero Destrucido" << endl;
}
void Mamifero::mostrarAnimal(){
    Animal::mostrarAnimal();
    cout << "Mamifero alimentacion: " << alimentacion << endl;
}

Perro.h

#ifndef ACTIVIDAD1_PERRO_H
#define ACTIVIDAD1_PERRO_H
#include <string>

#include "Mamifero.h"


class Perro : public Mamifero {
private:
    string tam;
